# ------------------------------
# Required: Supabase
# ------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ------------------------------
# Required: Database (Prisma)
# In serverless runtime, app code prefers DATABASE_URL (pooler).
# DIRECT_URL is used for migrations/direct connections.
# ------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DB_NAME?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ------------------------------
# Optional: Site URL helpers
# ------------------------------
NEXT_PUBLIC_SITE_URL="https://yaanalivings.com"

# Optional on Vercel (usually auto-injected):
# VERCEL_URL="your-app.vercel.app"

# ------------------------------
# Optional: Logging
# ------------------------------
# Set to "true" to enable error logging in server logs.
LOG_ERRORS="false"
# Set to "true" to enable error logging in client/browser logs.
NEXT_PUBLIC_LOG_ERRORS="false"
